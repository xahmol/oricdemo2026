# .env — local deployment configuration (gitignored, never committed)
# Copy this file to .env and fill in your values.

# Path for 'make usb' — the directory where .tap files will be copied.
# The directory must exist (USB must be mounted) when running make usb.
#
# Native Linux:
#   USBPATH = /media/yourname/USBSTICK/oric
#
# WSL2 (Windows Subsystem for Linux 2):
#   WSL2 auto-mounts Windows drives at /mnt/<letter> — no usbipd needed.
#   Plug in the USB stick; Windows assigns it a drive letter (e.g. E:);
#   WSL2 sees it at /mnt/e/. Create the target subdirectory first if needed.
#   idi8b distribution convention: idi8b/<ApplicationName>/<application files>
#   USBPATH = /mnt/e/idi8b/oricdemo2026
USBPATH = /mnt/e/idi8b/oricdemo2026

# Path to a built checkout of the Phosphoric Oric emulator (provides
# oric1-emu and roms/{basic11b.rom,loci/locirom}), used by 'make test*'
# for automated headless testing. See https://github.com/benedictemarty/Phosphoric
PHOSDIR = ~/Phosphoric
