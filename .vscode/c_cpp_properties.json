{
    "configurations": [
        {
            "name": "Linux",
            "includePath": [
                "${env:OSCAR64_HOME}/include/",
                "${workspaceFolder}/include",
                "${workspaceFolder}/src"
            ],
            "defines": [
                "NOFLOAT",
                "VERSION_MAJOR=0",
                "VERSION_MINOR=1",
                "VERSION_PATCH=0",
                "__noinline=",
                "__zeropage="
            ],
            "cStandard": "c23",
            "intelliSenseMode": "linux-gcc-x64"
        }
    ],
    "version": 4
}
